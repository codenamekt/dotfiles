# Ignore everything by default; explicitly allow tracked repo files and Stow package contents.
*

!.gitignore
!README.md
!bootstrap.sh

!tmux/
!vim/
!nvim/
!zsh/
!bat/
!fsh/
!eza/
!tmux/**
!vim/**
!nvim/**
!zsh/**
!bat/**
!fsh/**
!eza/**

# Ignore bat themes folder (specific subdirectory)
bat/.config/bat/themes/

# Generated / vendor plugin directories.
tmux/.tmux/plugins/
vim/.vim/plugged/
nvim/.local/share/nvim/lazy/
zsh/.zsh/oh-my-zsh/
zsh/.zsh/.zcompdump*
zsh/.zsh/custom/plugins/zsh-autosuggestions/
zsh/.zsh/custom/plugins/zsh-history-substring-search/
zsh/.zsh/custom/plugins/zsh-vi-mode/
zsh/.zsh/custom/plugins/fast-syntax-highlighting/
bat/.config/bat/themes/catppuccin/

# Shell and REPL histories.
.zsh_history
.zsh_history.*
.bash_history
.bash_history.*
.fish_history
.fish_history.*
.nushell/history.txt
.nushell/history.txt.*
.python_history
.node_repl_history
